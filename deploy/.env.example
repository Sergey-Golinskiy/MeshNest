# --- Cloudflare Tunnel ---
# Get this token from Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# --- Domain ---
PUBLIC_URL=https://meshnest.example.com
FRONTEND_URL=https://meshnest.example.com

# --- App secrets (generate with: openssl rand -hex 32) ---
JWT_SECRET=change-me-to-32-bytes-of-random-hex
POSTGRES_USER=meshnest
POSTGRES_PASSWORD=change-me-postgres-pass
POSTGRES_DB=meshnest

# MinIO root
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-pass

# Meilisearch master key
MEILI_MASTER_KEY=change-me-meili-master-key

# --- Database URLs (don't usually need to override) ---
DATABASE_URL=postgresql+asyncpg://meshnest:change-me-postgres-pass@postgres:5432/meshnest
DATABASE_URL_SYNC=postgresql+psycopg2://meshnest:change-me-postgres-pass@postgres:5432/meshnest

# --- Storage ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-pass

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Search ---
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me-meili-master-key

# --- SMTP for invite emails (optional in MVP1, invites work via copied URLs) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=MeshNest <noreply@meshnest.example.com>
SMTP_USE_TLS=true

# --- App config ---
ENVIRONMENT=prod
LOG_LEVEL=INFO
CORS_ORIGINS=["https://meshnest.example.com"]
